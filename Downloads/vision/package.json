{
  "name": "signbridge",
  "version": "0.1.0",
  "private": true,
  "description": "SignBridge - AI-powered accessibility platform bridging deaf, hard-of-hearing, and hearing individuals via real-time sign language recognition and translation.",
  "homepage": "https://github.com/kommerasachit/signbridge#readme",
  "bugs": {
    "url": "https://github.com/kommerasachit/signbridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kommerasachit/signbridge.git"
  },
  "author": "Kommera Sachit Reddy",
  "license": "AGPL-3.0-only",
  "keywords": [
    "accessibility",
    "sign-language",
    "deaf",
    "hard-of-hearing",
    "ai",
    "mediapipe",
    "tensorflow",
    "translation",
    "gesture-recognition",
    "typescript"
  ],
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit --audit-level=high",
    "knip": "knip",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^9.0.0",
    "knip": "^5.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
