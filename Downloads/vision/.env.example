# Database
DATABASE_URL=postgresql://signbridge:signbridge@localhost:5432/signbridge?schema=public

# API
API_PORT=8080
API_HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change-me-please-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-please-use-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Logging
LOG_LEVEL=info

# Web
VITE_API_BASE_URL=http://localhost:8080/api
